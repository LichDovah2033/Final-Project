generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
  role     Role   @default(USER)
  cart     Cart?
}

model Cart {
  id      Int      @id @default(autoincrement())
  userId  Int      @unique
  user    User     @relation(fields: [userId], references: [id])
  weapons Weapon[] @relation("CartWeapons")
  armors  Armor[]  @relation("CartArmors")
}

model Weapon {
  id          Int    @id @default(autoincrement())
  name        String
  damageValue Int
  price       Float
  carts       Cart[] @relation("CartWeapons")
}

model Armor {
  id              Int    @id @default(autoincrement())
  name            String
  protectionValue Int
  price           Float
  carts           Cart[] @relation("CartArmors")
}

enum Role {
  USER
  ADMIN
}
